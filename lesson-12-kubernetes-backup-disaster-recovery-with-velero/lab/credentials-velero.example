# Example credentials file for Velero's AWS plugin.
# Copy this to `credentials-velero` (no extension) in the same directory, fill in
# real values, and NEVER commit the filled-in version — add `credentials-velero`
# to .gitignore. These are long-lived IAM access keys with S3 permissions.
[default]
aws_access_key_id=<AWS_ACCESS_KEY_ID>
aws_secret_access_key=<AWS_SECRET_ACCESS_KEY>
